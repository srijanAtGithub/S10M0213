{
  "manifest_version": 3,
  "name": "Sicily Navigator (Demo)",
  "version": "0.1.0",
  "description": "Demo build \u2014 no AI yet. Chat interface that echoes back the current page's title and URL.",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sicily Navigator (Demo)"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "icon.png"
  }
}